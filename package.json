{
  "name": "lumen",
  "displayName": "Lumen",
  "description": "Lumen local-first learning environment for C inside VS Code.",
  "version": "0.0.1",
  "private": true,
  "publisher": "lumen",
  "type": "commonjs",
  "main": "./extension/out/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Education"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:lumen.open",
    "onCommand:lumen.enterMode",
    "onCommand:lumen.exitMode",
    "onCommand:lumen.engineStatus",
    "onCommand:lumen.refreshWebview",
    "onCommand:lumen.compileCurrentExercise",
    "onCommand:lumen.testCurrentExercise",
    "onCommand:lumen.importExercise",
    "onView:lumen.routePath",
    "workspaceContains:.lumen-perf-auto-open"
  ],
  "contributes": {
    "configuration": {
      "title": "Lumen",
      "properties": {
        "lumen.entryStyle": {
          "type": "string",
          "enum": ["velocity", "iris", "eclipse", "lens", "tide"],
          "default": "eclipse",
          "markdownDescription": "Estilo de la transición de entrada a Lumen Mode. `eclipse` (predeterminado): dip-to-black cinematográfico que enlaza con la pantalla de destino. `velocity`: zoom óptico con impacto. `iris`: implosión luminosa. `lens` y `tide`: variantes de exploración. Se aplica en la siguiente entrada a Lumen."
        },
        "lumen.tramoDemo": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Herramienta de verificación visual que recorre automáticamente tramos cortos de la ruta para comprobar el scroll real. Requiere recargar la vista de Lumen."
        }
      }
    },
    "commands": [
      {
        "command": "lumen.open",
        "title": "Lumen: Open Lumen",
        "category": "Lumen",
        "icon": {
          "light": "assets/brand/lumen-editor-icon.svg",
          "dark": "assets/brand/lumen-editor-icon.svg"
        }
      },
      {
        "command": "lumen.enterMode",
        "title": "Lumen: Enter Mode",
        "category": "Lumen",
        "icon": {
          "light": "assets/brand/lumen-editor-icon.svg",
          "dark": "assets/brand/lumen-editor-icon.svg"
        }
      },
      {
        "command": "lumen.exitMode",
        "title": "Lumen: Exit Mode",
        "category": "Lumen"
      },
      {
        "command": "lumen.engineStatus",
        "title": "Lumen: Engine Status",
        "category": "Lumen"
      },
      {
        "command": "lumen.refreshWebview",
        "title": "Lumen: Refresh Webview",
        "category": "Lumen"
      },
      {
        "command": "lumen.compileCurrentExercise",
        "title": "Lumen: Compilar Ejercicio Actual",
        "category": "Lumen"
      },
      {
        "command": "lumen.testCurrentExercise",
        "title": "Lumen: Probar Solucion",
        "category": "Lumen"
      },
      {
        "command": "lumen.importExercise",
        "title": "Lumen: Importar Ejercicio (.esex)",
        "category": "Lumen"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lumen",
          "title": " ",
          "icon": "assets/brand/lumen-activitybar-icon.svg"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "lumen.open",
          "group": "navigation@0"
        }
      ]
    },
    "views": {
      "lumen": [
        {
          "id": "lumen.routePath",
          "name": " ",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "key": "escape",
        "command": "lumen.exitMode",
        "when": "lumen.inMode && !inQuickOpen && !suggestWidgetVisible && !findWidgetVisible && !renameInputVisible && !parameterHintsVisible && !inSnippetMode && !editorHasSelection && !editorHasMultipleSelections"
      },
      {
        "key": "f9",
        "command": "lumen.compileCurrentExercise",
        "when": "lumen.inMode && lumen.hasActiveExercise && editorTextFocus"
      },
      {
        "key": "f10",
        "command": "lumen.testCurrentExercise",
        "when": "lumen.inMode && lumen.hasActiveExercise && editorTextFocus"
      }
    ]
  },
  "scripts": {
    "dev:frontend": "bun run --cwd frontend dev",
    "build:frontend": "bun run --cwd frontend build",
    "compile:extension": "tsc -p extension/tsconfig.json",
    "watch:extension": "tsc -w -p extension/tsconfig.json",
    "build:engine": "cargo build --release --manifest-path engine/Cargo.toml",
    "build:package-assets": "node scripts/build-package-assets.mjs",
    "build": "bun run build:frontend && bun run compile:extension && bun run build:engine && bun run build:package-assets",
    "verify:package": "node scripts/verify-package.mjs",
    "test:frontend": "bun test frontend/test",
    "perf:harness": "node scripts/perf-harness.mjs",
    "perf:smoke": "set PERF_WARMUPS=0&& set PERF_ITERATIONS=1&& node scripts/perf-harness.mjs",
    "perf:baseline": "set PERF_WARMUPS=5&& set PERF_ITERATIONS=30&& node scripts/perf-harness.mjs",
    "install:local": "node scripts/install-local.mjs",
    "build:local": "bun run build && bun run install:local"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3"
  }
}
