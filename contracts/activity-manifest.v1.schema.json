{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumen.local/contracts/activity-manifest.v1.schema.json",
  "title": "Lumen Activity Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "kind",
    "title",
    "summary",
    "language",
    "status",
    "skills",
    "difficulty",
    "execution",
    "content",
    "compatibility"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/activityId" },
    "version": { "$ref": "#/$defs/semver" },
    "kind": { "enum": ["practice", "challenge", "quiz", "project", "assessment"] },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "status": { "enum": ["draft", "review", "approved"] },
    "source": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string", "format": "uri" },
    "origin": { "$ref": "#/$defs/origin" },
    "primaryTopics": { "$ref": "#/$defs/topicList" },
    "supportTopics": { "$ref": "#/$defs/topicList" },
    "combinedTopics": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9-]+(?:\\+[a-z0-9-]+)+$" }
    },
    "requiredMastery": {
      "type": "array",
      "items": { "$ref": "#/$defs/requiredMastery" }
    },
    "newTopicFocus": { "$ref": "#/$defs/topicList" },
    "learningObjectives": {
      "type": "array",
      "items": { "$ref": "#/$defs/learningObjective" }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/activitySkill" }
    },
    "prerequisites": {
      "type": "array",
      "items": { "$ref": "#/$defs/prerequisite" }
    },
    "commonErrors": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/kebabId" }
    },
    "misconceptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/misconceptionRelation" }
    },
    "remediates": { "$ref": "#/$defs/activityRelations" },
    "preparesFor": { "$ref": "#/$defs/activityRelations" },
    "relatedProjects": { "$ref": "#/$defs/activityRelations" },
    "contentFamily": {
      "oneOf": [{ "$ref": "#/$defs/activityId" }, { "type": "null" }]
    },
    "variantOf": {
      "oneOf": [{ "$ref": "#/$defs/activityId" }, { "type": "null" }]
    },
    "contrastsWith": { "$ref": "#/$defs/activityRelations" },
    "alternativeTo": { "$ref": "#/$defs/activityRelations" },
    "supersedes": { "$ref": "#/$defs/activityRelations" },
    "transferProfile": { "$ref": "#/$defs/transferProfile" },
    "solutionSpace": { "$ref": "#/$defs/solutionSpace" },
    "route": { "$ref": "#/$defs/route" },
    "visibility": { "$ref": "#/$defs/visibility" },
    "difficulty": { "$ref": "#/$defs/difficulty" },
    "unlock": { "$ref": "#/$defs/unlock" },
    "scaffolding": { "$ref": "#/$defs/scaffolding" },
    "recommendationPolicy": { "$ref": "#/$defs/recommendationPolicy" },
    "testContract": { "$ref": "#/$defs/testContract" },
    "evidenceContract": { "$ref": "#/$defs/evidenceContract" },
    "execution": { "$ref": "#/$defs/execution" },
    "sandbox": { "$ref": "#/$defs/sandbox" },
    "content": { "$ref": "#/$defs/content" },
    "localization": { "$ref": "#/$defs/localization" },
    "accessibility": { "$ref": "#/$defs/accessibility" },
    "compatibility": { "$ref": "#/$defs/compatibility" },
    "curation": { "$ref": "#/$defs/curation" },
    "requiredSkills": {
      "type": "array",
      "items": { "$ref": "#/$defs/projectSkill" }
    },
    "integrationSkills": {
      "type": "array",
      "items": { "$ref": "#/$defs/projectSkill" }
    },
    "milestones": {
      "type": "array",
      "items": { "$ref": "#/$defs/milestone" }
    },
    "deliverables": {
      "type": "array",
      "items": { "$ref": "#/$defs/deliverable" }
    },
    "rubricCriteria": {
      "type": "array",
      "items": { "$ref": "#/$defs/rubricCriterion" }
    },
    "stretchGoals": {
      "type": "array",
      "items": { "$ref": "#/$defs/stretchGoal" }
    },
    "recommendedPreparation": {
      "type": "array",
      "items": { "$ref": "#/$defs/activityId" }
    },
    "introducesNovelty": { "type": "boolean" },
    "completionEvidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/completionEvidence" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "kind": { "enum": ["practice", "challenge"] } },
        "required": ["kind"]
      },
      "then": { "required": ["testContract", "evidenceContract"] }
    },
    {
      "if": {
        "properties": { "kind": { "const": "project" } },
        "required": ["kind"]
      },
      "then": {
        "required": [
          "requiredSkills",
          "integrationSkills",
          "milestones",
          "deliverables",
          "rubricCriteria",
          "stretchGoals",
          "recommendedPreparation",
          "introducesNovelty",
          "completionEvidence"
        ]
      }
    }
  ],
  "$defs": {
    "activityId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+){2,}$"
    },
    "taxonomyId": {
      "type": "string",
      "pattern": "^[a-z0-9-]+\\.[a-z0-9-]+$"
    },
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "topicId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "moduleId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
    },
    "unitInterval": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "dimension": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "criticality": {
      "enum": ["critical", "major", "supporting"]
    },
    "topicList": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/topicId" }
    },
    "activityRelations": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/activityId" }
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relationship"],
      "properties": {
        "relationship": { "enum": ["original", "adapted", "inspired-by"] },
        "platform": { "type": "string", "minLength": 1 },
        "itemId": { "type": "string", "minLength": 1 },
        "originalTitle": { "type": "string", "minLength": 1 },
        "originalAuthors": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "copyrightHolder": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "attribution": { "type": "string" },
        "modificationsSummary": { "type": "string" }
      }
    },
    "requiredMastery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "minimumMastery"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[.-][a-z0-9-]+)*$"
        },
        "kind": { "enum": ["topic", "module", "skill"] },
        "minimumMastery": { "$ref": "#/$defs/unitInterval" },
        "minimumConfidence": { "$ref": "#/$defs/unitInterval" }
      }
    },
    "learningObjective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "skillIds", "successCriterion", "criticality"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "description": { "type": "string", "minLength": 1 },
        "skillIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/taxonomyId" }
        },
        "successCriterion": { "type": "string", "minLength": 1 },
        "criticality": { "$ref": "#/$defs/criticality" }
      }
    },
    "activitySkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "weight", "criticality", "evidenceStrength"],
      "properties": {
        "id": { "$ref": "#/$defs/taxonomyId" },
        "role": { "enum": ["introduces", "practices", "reinforces", "assesses", "integrates"] },
        "weight": { "$ref": "#/$defs/unitInterval" },
        "criticality": { "$ref": "#/$defs/criticality" },
        "evidenceStrength": { "$ref": "#/$defs/unitInterval" }
      }
    },
    "prerequisite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skillId", "minimumMastery", "minimumConfidence", "kind"],
      "properties": {
        "skillId": { "$ref": "#/$defs/taxonomyId" },
        "minimumMastery": { "$ref": "#/$defs/unitInterval" },
        "minimumConfidence": { "$ref": "#/$defs/unitInterval" },
        "kind": { "enum": ["hard", "soft", "recommended"] },
        "rationale": { "type": "string" }
      }
    },
    "misconceptionRelation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role"],
      "properties": {
        "id": { "$ref": "#/$defs/taxonomyId" },
        "role": { "enum": ["reveals", "remediates", "guardsAgainst"] },
        "diagnosticSignals": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "confidenceCeiling": { "$ref": "#/$defs/unitInterval" }
      }
    },
    "transferProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["distance", "noveltyDimensions", "contextShift"],
      "properties": {
        "distance": { "enum": ["near", "medium", "far"] },
        "noveltyDimensions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "contextShift": { "type": "string", "minLength": 1 }
      }
    },
    "solutionSpace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["breadth", "acceptedStrategies", "discouragedShortcuts", "complexityExpectations"],
      "properties": {
        "breadth": { "enum": ["narrow", "moderate", "broad", "open"] },
        "acceptedStrategies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "discouragedShortcuts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "complexityExpectations": { "type": "string", "minLength": 1 }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routeEligible", "masteryChallengeEligible", "freeModeAfterUnlock"],
      "properties": {
        "routeEligible": { "type": "boolean" },
        "routeId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "moduleId": { "$ref": "#/$defs/moduleId" },
        "orderInModule": { "type": "integer" },
        "role": { "enum": ["required", "recommended", "reinforcement", "extra", "gate", "project"] },
        "masteryChallengeEligible": { "type": "boolean" },
        "freeModeAfterUnlock": { "type": "boolean" },
        "nodeType": { "type": "string", "minLength": 1 }
      }
    },
    "visibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categoryVisible", "projectEligible", "recommendable"],
      "properties": {
        "categoryVisible": { "type": "boolean" },
        "projectEligible": { "type": "boolean" },
        "recommendable": { "type": "boolean" },
        "searchable": { "type": "boolean" },
        "previewableWhenLocked": { "type": "boolean" },
        "featuredEligible": { "type": "boolean" },
        "allowedContexts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["route", "free"] }
        }
      }
    },
    "difficulty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "band"],
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "band": { "enum": ["intro", "easy", "easy+", "medium", "medium+", "hard", "challenge"] },
        "conceptualLevel": { "$ref": "#/$defs/dimension" },
        "syntaxLoad": { "$ref": "#/$defs/dimension" },
        "stateControl": { "$ref": "#/$defs/dimension" },
        "loopDepth": { "$ref": "#/$defs/dimension" },
        "functionComplexity": { "$ref": "#/$defs/dimension" },
        "arrayComplexity": { "$ref": "#/$defs/dimension" },
        "matrixComplexity": { "$ref": "#/$defs/dimension" },
        "stringComplexity": { "$ref": "#/$defs/dimension" },
        "pointerDepth": { "$ref": "#/$defs/dimension" },
        "dynamicMemoryRisk": { "$ref": "#/$defs/dimension" },
        "structComplexity": { "$ref": "#/$defs/dimension" },
        "fileIoComplexity": { "$ref": "#/$defs/dimension" },
        "inputParsingComplexity": { "$ref": "#/$defs/dimension" },
        "hiddenTraps": { "$ref": "#/$defs/dimension" },
        "debugDifficulty": { "$ref": "#/$defs/dimension" },
        "algorithmicComplexity": { "$ref": "#/$defs/dimension" },
        "dataFlowComplexity": { "$ref": "#/$defs/dimension" },
        "edgeCaseDensity": { "$ref": "#/$defs/dimension" },
        "noveltyLoad": { "$ref": "#/$defs/dimension" },
        "readingLoad": { "$ref": "#/$defs/dimension" },
        "toolingLoad": { "$ref": "#/$defs/dimension" },
        "interactionComplexity": { "$ref": "#/$defs/dimension" },
        "expectedMinutes": { "type": "integer", "minimum": 1 },
        "expectedMinutesRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer", "minimum": 1 },
            "max": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "unlockSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skillId", "minimumMastery"],
      "properties": {
        "skillId": { "$ref": "#/$defs/taxonomyId" },
        "minimumMastery": { "$ref": "#/$defs/unitInterval" },
        "minimumConfidence": { "$ref": "#/$defs/unitInterval" }
      }
    },
    "unlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logic"],
      "properties": {
        "requiresModules": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/moduleId" }
        },
        "requiresExercises": { "$ref": "#/$defs/activityRelations" },
        "requiresQuizScore": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["activityId", "minimumScore"],
              "properties": {
                "activityId": { "$ref": "#/$defs/activityId" },
                "minimumScore": { "$ref": "#/$defs/unitInterval" }
              }
            }
          ]
        },
        "requiresSkills": {
          "type": "array",
          "items": { "$ref": "#/$defs/unlockSkill" }
        },
        "requiresProjects": { "$ref": "#/$defs/activityRelations" },
        "requiresRouteProgress": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["routeId", "minimumProgress"],
              "properties": {
                "routeId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
                "minimumProgress": { "$ref": "#/$defs/unitInterval" }
              }
            }
          ]
        },
        "logic": { "enum": ["all", "any"] }
      }
    },
    "scaffolding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scaffoldingLevel", "starterCompleteness", "guidedSteps", "hintPolicy"],
      "properties": {
        "scaffoldingLevel": { "$ref": "#/$defs/dimension" },
        "starterCompleteness": { "$ref": "#/$defs/unitInterval" },
        "guidedSteps": { "type": "boolean" },
        "hintPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxHints", "generationMode", "revealSolution"],
          "properties": {
            "maxHints": { "type": "integer", "minimum": 0 },
            "generationMode": { "enum": ["authored", "contextual-ai", "hybrid"] },
            "progression": { "type": "string", "minLength": 1 },
            "revealSolution": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "recommendationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligibleContexts", "purposes", "repeatable"],
      "properties": {
        "eligibleContexts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["route", "free"] }
        },
        "purposes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["learn", "practice", "reinforce", "remediate", "review", "assess", "transfer", "prepare-project"] }
        },
        "repeatable": { "type": "boolean" },
        "cooldownDays": { "type": "integer", "minimum": 0 },
        "contentFamilyCooldown": { "type": "integer", "minimum": 0 },
        "diversityTags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "targetDifficultyWindow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer", "minimum": -100, "maximum": 100 },
            "max": { "type": "integer", "minimum": -100, "maximum": 100 }
          }
        }
      }
    },
    "testGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "phase", "weight"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "phase": { "enum": ["compile", "public", "local-private", "local-additional", "property", "style"] },
        "weight": { "$ref": "#/$defs/unitInterval" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeLimitMs": { "type": "integer", "minimum": 1 },
        "memoryLimitMb": { "type": "integer", "minimum": 1 },
        "outputLimitKb": { "type": "integer", "minimum": 1 }
      }
    },
    "testContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowAdapter", "allowAiAdapter", "adapterPolicy", "phases", "testGroups", "limits"],
      "properties": {
        "contractVersion": { "type": "integer", "minimum": 1 },
        "mode": { "enum": ["io", "function", "hybrid"] },
        "preferred": { "enum": ["io", "function"] },
        "fallback": { "enum": ["io", "function"] },
        "allowAdapter": { "type": "boolean" },
        "allowAiAdapter": { "type": "boolean" },
        "adapterPolicy": { "enum": ["forbidden", "prebuilt-reviewed"] },
        "phases": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["compile", "public", "local-private", "local-additional", "property", "style"] }
        },
        "comparator": { "type": "string", "minLength": 1 },
        "normalization": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "expectedExitCode": { "type": "integer" },
        "deterministic": { "type": "boolean" },
        "seedPolicy": { "type": "string", "minLength": 1 },
        "scoring": { "type": "string", "minLength": 1 },
        "testGroups": {
          "type": "array",
          "items": { "$ref": "#/$defs/testGroup" }
        },
        "limits": { "$ref": "#/$defs/limits" }
      }
    },
    "evidenceGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "weight", "polarity", "confidence"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "skillId": {
          "oneOf": [{ "$ref": "#/$defs/taxonomyId" }, { "type": "null" }]
        },
        "misconceptionId": {
          "oneOf": [{ "$ref": "#/$defs/taxonomyId" }, { "type": "null" }]
        },
        "weight": { "$ref": "#/$defs/unitInterval" },
        "polarity": { "enum": ["positive", "negative", "bidirectional"] },
        "confidence": { "$ref": "#/$defs/unitInterval" },
        "maxEvidencePerAttempt": { "$ref": "#/$defs/unitInterval" },
        "requiresUnassisted": { "type": "boolean" }
      }
    },
    "evidenceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["groups"],
      "properties": {
        "groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceGroup" }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compileProfile", "entrypoint"],
      "properties": {
        "languageStandard": { "type": "string", "minLength": 1 },
        "compileProfile": { "type": "string", "minLength": 1 },
        "executionMode": { "type": "string", "minLength": 1 },
        "entrypoint": { "type": "string", "minLength": 1 },
        "additionalSources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "sourceEncoding": { "type": "string", "minLength": 1 },
        "requiredHeaders": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredLibraries": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "platformCapabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "allowedDefines": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "warningsPolicy": { "type": "string", "minLength": 1 },
        "inputModel": { "type": "string", "minLength": 1 },
        "outputModel": { "type": "string", "minLength": 1 },
        "sandboxProfile": { "type": "string", "minLength": 1 }
      }
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": { "type": "boolean", "default": false },
        "filesystemScope": { "type": "string", "minLength": 1 },
        "childProcesses": { "type": "boolean" },
        "stdin": { "type": "boolean" },
        "timeLimitMs": { "type": "integer", "minimum": 1 },
        "memoryLimitMb": { "type": "integer", "minimum": 1 },
        "outputLimitKb": { "type": "integer", "minimum": 1 },
        "temporaryDiskMb": { "type": "integer", "minimum": 0 },
        "processLimit": { "type": "integer", "minimum": 1 }
      }
    },
    "contentReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "locale": { "$ref": "#/$defs/locale" },
        "editable": { "type": "boolean" },
        "required": { "type": "boolean" },
        "mediaType": { "type": "string", "minLength": 1 }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "statement": { "$ref": "#/$defs/contentReference" },
        "starter": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentReference" }
        },
        "tests": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentReference" }
        },
        "hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentReference" }
        },
        "assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentReference" }
        },
        "readme": { "$ref": "#/$defs/contentReference" }
      }
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "statement": { "$ref": "#/$defs/contentReference" },
        "hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/contentReference" }
        }
      }
    },
    "localization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultLocale", "availableLocales", "localizedContent"],
      "properties": {
        "defaultLocale": { "$ref": "#/$defs/locale" },
        "availableLocales": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/locale" }
        },
        "localizedContent": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$": { "$ref": "#/$defs/localizedText" }
          },
          "additionalProperties": false
        }
      }
    },
    "stringMap": {
      "type": "object",
      "patternProperties": {
        "^.+$": { "type": "string" }
      },
      "additionalProperties": false
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assetAltText": { "$ref": "#/$defs/stringMap" },
        "longDescriptions": { "$ref": "#/$defs/stringMap" },
        "transcripts": { "$ref": "#/$defs/stringMap" },
        "plainTextFallbacks": { "$ref": "#/$defs/stringMap" },
        "motionWarnings": { "type": "boolean" },
        "colorIndependentInstructions": { "type": "boolean" }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minEngineVersion", "taxonomyVersion"],
      "properties": {
        "minEngineVersion": { "$ref": "#/$defs/semver" },
        "supportedPlatforms": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredCapabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "taxonomyVersion": { "const": 1 },
        "migrationNotes": {
          "type": ["string", "null"]
        },
        "updateCompatibility": { "enum": ["compatible", "manual-review", "breaking"] }
      }
    },
    "curation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "curators": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "pedagogicalRationale": { "type": "string", "minLength": 1 },
        "qualityReview": { "enum": ["pending", "review", "approved", "rejected"] },
        "aiAssisted": { "type": "boolean" },
        "reviewedAt": { "type": "string", "format": "date" },
        "reviewerRole": { "type": "string", "minLength": 1 }
      }
    },
    "projectSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skillId", "minimumMastery", "minimumConfidence", "criticality"],
      "properties": {
        "skillId": { "$ref": "#/$defs/taxonomyId" },
        "minimumMastery": { "$ref": "#/$defs/unitInterval" },
        "minimumConfidence": { "$ref": "#/$defs/unitInterval" },
        "criticality": { "$ref": "#/$defs/criticality" }
      }
    },
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "requiredSkillIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/taxonomyId" }
        }
      }
    },
    "deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "required"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "description": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "rubricCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "weight"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "description": { "type": "string", "minLength": 1 },
        "weight": { "$ref": "#/$defs/unitInterval" },
        "skillIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/taxonomyId" }
        }
      }
    },
    "stretchGoal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "completionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "weight"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "skillId": { "$ref": "#/$defs/taxonomyId" },
        "weight": { "$ref": "#/$defs/unitInterval" }
      }
    }
  }
}
