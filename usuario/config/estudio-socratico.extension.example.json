{
  "provider": "gemini",
  "apiKey": "",
  "model": "gemini-2.5-flash",
  "features": {
    "translateIntroductions": true,
    "importExercism": true,
    "importAlejandroGists": true,
    "aiExerciseAnalysis": false,
