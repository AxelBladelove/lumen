{
  "formatVersion": 1,
  "cases": [
    {
      "id": "basic-phrase",
      "group": "echo",
      "stdin": "Hola Mundo\n",
      "expectedStdout": "Hola Mundo\n"
    },
    {
      "id": "digits-and-symbols",
      "group": "echo",
      "stdin": "abc 123!\n",
      "expectedStdout": "abc 123!\n"
    },
    {
      "id": "leading-spaces",
      "group": "echo",
      "stdin": "  dos espacios\n",
      "expectedStdout": "  dos espacios\n"
    },
    {
      "id": "single-char",
      "group": "echo",
      "stdin": "x\n",
      "expectedStdout": "x\n"
    },
    {
      "id": "empty-line",
      "group": "boundaries",
      "stdin": "\n",
      "expectedStdout": "\n"
    },
    {
      "id": "no-input",
      "group": "boundaries",
      "stdin": "",
      "expectedStdout": "\n"
    },
    {
      "id": "without-final-newline",
      "group": "boundaries",
      "stdin": "sin salto",
      "expectedStdout": "sin salto\n"
    },
    {
      "id": "ascii-fence",
      "group": "boundaries",
      "stdin": "AZaz@[`{\n",
      "expectedStdout": "AZaz@[`{\n"
    },
    {
      "id": "long-line",
      "group": "boundaries",
      "stdin": "\n",
      "expectedStdout": "\n"
    }
  ]
}
