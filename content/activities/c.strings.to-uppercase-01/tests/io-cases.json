{
  "formatVersion": 1,
  "cases": [
    {
      "id": "basic-phrase",
      "group": "conversion",
      "stdin": "Hola Mundo\n",
      "expectedStdout": "HOLA MUNDO\n"
    },
    {
      "id": "digits-and-symbols",
      "group": "conversion",
      "stdin": "abc 123!\n",
      "expectedStdout": "ABC 123!\n"
    },
    {
      "id": "already-uppercase",
      "group": "conversion",
      "stdin": "ABC XYZ\n",
      "expectedStdout": "ABC XYZ\n"
    },
    {
      "id": "mixed-case",
      "group": "conversion",
      "stdin": "LuMeN\n",
      "expectedStdout": "LUMEN\n"
    },
    {
      "id": "empty-line",
      "group": "boundaries",
      "stdin": "\n",
      "expectedStdout": "\n"
    },
    {
      "id": "no-input",
      "group": "boundaries",
      "stdin": "",
      "expectedStdout": "\n"
    },
    {
      "id": "without-final-newline",
      "group": "boundaries",
      "stdin": "sin salto",
      "expectedStdout": "SIN SALTO\n"
    },
    {
      "id": "ascii-fence",
      "group": "boundaries",
      "stdin": "AZaz@[`{\n",
      "expectedStdout": "AZAZ@[`{\n"
    },
    {
      "id": "symbols-only",
      "group": "boundaries",
      "stdin": "123 !?_-[]{}\n",
      "expectedStdout": "123 !?_-[]{}\n"
    },
    {
      "id": "long-line",
      "group": "boundaries",
      "stdin": "\n",
      "expectedStdout": "\n"
    }
  ]
}
